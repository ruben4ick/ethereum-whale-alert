        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, rate(block_processing_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 Latency",
          "refId": "B"
        }
      ],
      "title": "Block Processing Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
